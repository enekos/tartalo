{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "tartalo",
      "camelcase": "Tartalo",
      "scope": "source.tartalo",
      "path": ".",
      "file-types": ["tt"],
      "highlights": ["queries/highlights.scm"],
      "injection-regex": "^tartalo$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Tartalo",
    "authors": [
      { "name": "Tartalo authors" }
    ]
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
